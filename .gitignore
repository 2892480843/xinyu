.DS_Store

# Runtime data
backend/app/data/*.db
backend/app/data/*.db-*
backend/app/data/memories.json
backend/app/data/chroma/
backend/data/

# 运行时日志 / 数据库备份（不入版本库）
backend/logs/
backend/backups/

# Python
backend/.venv/
__pycache__/
*.py[cod]

# Frontend
frontend/node_modules/
frontend/dist/
frontend/shot-*.png

# 音频素材原始存档（可由 public/audio/fetch_assets.py 重新抓取，不入版本库）
frontend/public/audio/raw/

# 大型模型素材源压缩包（解压后的 glb 已入库，源 zip 不入版本库）
frontend/public/models/dutch-ship-medium.zip

# Local env
.env
*.local

# 写实大模型的未压缩原件归档(原画备份);工作区/dist 用 meshopt+webp 压缩版
/_model_originals/

# 演示 / 路演 / 演讲 / 参赛物料与过程记录（仅本地留存，不入版本库）
*.docx
*.pptx
/pptx_build/
/iflow.md
/yfork.mjs
