# LLM 提供方: mock(默认，无需 Key) | openai(兼容 OpenAI 接口的任意服务)
LLM_PROVIDER=mock

# 仅当 LLM_PROVIDER=openai 时生效。调用失败会自动降级到 mock，保证演示不中断。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# 接入腾讯云混元（OpenAI 兼容接口）示例：
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=你的混元 API Key
#   OPENAI_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
#   OPENAI_MODEL=hunyuan-turbos-latest

# 允许访问后端 API 的前端来源。生产环境请改成真实域名，不要使用 *。
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# —— PostgreSQL ——（memories/artifacts/phrases 关系表 + pgvector 语义索引的唯一持久化）
# 标准 libpq 连接串。先创建数据库与扩展：
#   createdb xinyu && psql -d xinyu -c 'CREATE EXTENSION IF NOT EXISTS vector'
# 也支持完整形式：postgresql://user:password@host:5432/xinyu
DATABASE_URL=postgresql://localhost:5432/xinyu
# 连接池大小（按部署并发调整）
PG_POOL_MIN=1
PG_POOL_MAX=10

# —— 语义记忆（pgvector + 本地 fastembed embedding）——
# 关系表是基础持久化；向量检索只增强「找回相关旧记忆」。embedding 走本地 ONNX 模型，
# 首次自动下载缓存、可离线、无需 API Key。不可用时自动降级为「最近记忆」，不阻塞主流程。
# VECTOR_ENABLED=0 可完全关闭语义检索。EMBEDDING_DIM 必须与所选模型维度一致（建表用）。
VECTOR_ENABLED=1
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512
VECTOR_MEMORY_RESULTS=3

# —— 云端情感语音合成 TTS（可选）——
# 配好任一通道后，「朗读叙事」与自由探索中的精灵发声升级为云端情感音色；
# 未配置或调用失败时自动降级浏览器原生合成，断网 / 无密钥也能读。
# TTS_PROVIDER 显式选择通道：aliyun / tencent / 留空（留空时自动选已配置的一方，都配优先 aliyun）。
# TTS_PROVIDER=aliyun
# 阿里云 CosyVoice（DashScope）：
# DASHSCOPE_API_KEY=你的 DashScope API Key
# 腾讯云情感语音合成（区域 / 音色 / 超时均有默认值，可不填）：
# TENCENT_TTS_SECRET_ID=你的 SecretId
# TENCENT_TTS_SECRET_KEY=你的 SecretKey
# TENCENT_TTS_REGION=ap-guangzhou
# TENCENT_TTS_VOICE_TYPE=101016
# TENCENT_TTS_TIMEOUT=8
