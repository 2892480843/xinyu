# LLM 提供方: mock(默认，无需 Key) | openai(兼容 OpenAI 接口的任意服务)
LLM_PROVIDER=mock

# 仅当 LLM_PROVIDER=openai 时生效。调用失败会自动降级到 mock，保证演示不中断。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# 接入腾讯云混元（OpenAI 兼容接口）示例——答辩演示推荐，体现使用主办方云能力：
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=你的混元 API Key
#   OPENAI_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
#   OPENAI_MODEL=hunyuan-turbos-latest

# 允许访问后端 API 的前端来源。生产环境请改成真实域名，不要使用 *。
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# SQLite/JSON 本地记忆路径。SQLite 是基础持久化，JSON 仅用于查看和迁移。
MEMORY_DB=app/data/memories.db
MEMORY_JSON=app/data/memories.json

# ChromaDB 情感向量记忆。SQLite 仍是基础持久化；Chroma 不可用时自动降级。
CHROMA_ENABLED=1
CHROMA_DB_DIR=app/data/chroma
CHROMA_COLLECTION=xinyu_emotional_memories
VECTOR_MEMORY_RESULTS=3
